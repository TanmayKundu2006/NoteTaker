<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= filename.replace('.txt', '') %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 text-white">
    <div class="container mx-auto p-8">
        <header class="flex justify-between items-center mb-8">
            <h1 class="text-4xl font-bold"><%= filename.replace('.txt', '') %></h1>
            <div>
                <a href="/" class="text-blue-400 hover:text-blue-300 transition-colors mr-4">Back to Notes</a>
                <a href="/edit/<%= filename %>" class="text-green-400 hover:text-green-300 transition-colors">Edit</a>
            </div>
        </header>
        <main class="bg-zinc-800 p-6 rounded-lg shadow-lg">
            <p class="text-lg whitespace-pre-wrap"><%= filedata %></p>
        </main>
    </div>
</body>
</html>